generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Nonce {
  id            String   @id @default(uuid())
  walletAddress String   @unique
  nonce         String
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@map("Nonce")
}

model RefreshToken {
  id            String   @id @default(uuid())
  walletAddress String
  token         String   @unique
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([walletAddress])
  @@map("RefreshToken")
}

model Notification {
  id            String   @id @default(uuid())
  walletAddress String
  message       String
  orderId       String?
  type          String
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([walletAddress])
  @@index([walletAddress, createdAt(sort: Desc)])
  @@index([walletAddress, isRead])
  @@index([orderId])
}

model NotificationPreference {
  walletAddress String   @id
  preferences   Json
  updatedAt     DateTime @updatedAt

  @@map("notification_preferences")
}

model User {
  id            String   @id @default(uuid())
  walletAddress String   @unique
  role          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ordersAsBuyer  Order[] @relation("BuyerOrders")
  ordersAsSeller Order[] @relation("SellerOrders")

  @@map("users")
}

model BuyerDemand {
  id              String    @id @default(uuid())
  buyerWallet     String    @map("buyer_wallet")
  cropName        String    @map("crop_name")
  quantityWanted  String?   @map("quantity_wanted")
  unit            String?
  maxPricePerUnit String?   @map("max_price_per_unit")
  currency        String?
  region          String?
  notes           String?
  neededBy        DateTime? @map("needed_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([buyerWallet])
  @@map("buyer_demands")
}

model FarmerSupply {
  id                String    @id @default(uuid())
  farmerWallet      String    @map("farmer_wallet")
  cropName          String    @map("crop_name")
  quantityAvailable String    @map("quantity_available")
  unit              String?
  pricePerUnit      String?   @map("price_per_unit")
  currency          String?
  availableFrom     DateTime? @map("available_from")
  availableUntil    DateTime? @map("available_until")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([farmerWallet])
  @@map("farmer_supplies")
}

model Product {
  id           String   @id @default(uuid())
  farmerWallet String
  name         String
  pricePerUnit String   @map("price_per_unit")
  currency     String
  isAvailable  Boolean  @default(true) @map("is_available")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders       Order[]
  priceHistory PriceHistory[]

  @@map("products")
}

model Order {
  id             String   @id @default(uuid())
  orderIdOnChain String   @unique
  buyerAddress   String
  sellerAddress  String
  amount         String
  token          String
  status         String
  productId      String?
  txHash         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  buyerUser  User     @relation("BuyerOrders", fields: [buyerAddress], references: [walletAddress], onDelete: Cascade)
  sellerUser User     @relation("SellerOrders", fields: [sellerAddress], references: [walletAddress], onDelete: Cascade)
  product    Product? @relation(fields: [productId], references: [id])
  dispute    Dispute?

  @@index([sellerAddress])
  @@index([buyerAddress])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([sellerAddress, status])
  @@map("orders")
}

model Campaign {
  id                String   @id @default(uuid())
  campaignIdOnChain String   @unique
  creatorAddress    String
  goalAmount        String
  token             String
  status            String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([creatorAddress])
  @@map("campaigns")
}

model Investment {
  id                String   @id @default(uuid())
  sourceEventId     String   @unique
  campaignIdOnChain String
  investorAddress   String
  amount            String
  token             String
  txHash            String?
  createdAt         DateTime @default(now())

  @@index([campaignIdOnChain])
  @@index([investorAddress])
  @@map("investments")
}

model BlockchainTransaction {
  id                String   @id @default(uuid())
  sourceEventId     String   @unique
  eventType         String
  entity            String
  action            String
  ledger            Int
  eventIndex        Int
  txHash            String?
  orderIdOnChain    String?
  campaignIdOnChain String?
  payload           Json?
  createdAt         DateTime @default(now())

  @@unique([ledger, eventIndex])
  @@index([orderIdOnChain])
  @@index([campaignIdOnChain])
  @@map("transactions")
}

model EscrowEvent {
  id         String   @id @default(uuid())
  orderId    String
  buyer      String
  seller     String
  amount     String
  token      String
  action     String
  ledger     Int
  eventIndex Int
  timestamp  DateTime

  @@unique([ledger, eventIndex])
  @@map("escrow_events")
}

model EscrowTransaction {
  id             String   @id @default(uuid())
  orderIdOnChain String
  action         String
  ledger         Int
  timestamp      DateTime

  @@map("escrow_transactions")
}

model PriceHistory {
  id        String   @id @default(uuid())
  productId String
  price     String
  currency  String
  timestamp DateTime

  product Product @relation(fields: [productId], references: [id])

  @@map("price_history")
}

model Profile {
  wallet_address String    @id
  name           String?
  bio            String?
  avatar_url     String?
  role           String    @default("BUYER")
  location       Location?

  @@map("profiles")
}

model Location {
  wallet_address String   @id
  lat            Float    @map("latitude")
  lng            Float    @map("longitude")
  is_public      Boolean  @default(true)
  profile        Profile? @relation(fields: [wallet_address], references: [wallet_address])

  @@map("locations")
}

model OrderMetadata {
  on_chain_order_id String @id
  description       String
  farmer_address    String
  buyer_address     String

  @@map("order_metadata")
}

model ContractWatcherCheckpoint {
  service    String   @id
  lastLedger Int      @map("last_ledger")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("contract_watcher_checkpoints")
}

model Dispute {
  id             String    @id @default(uuid())
  orderIdOnChain String    @unique
  raisedBy       String
  status         String
  outcome        String?
  evidenceHash   String?
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?

  order Order @relation(fields: [orderIdOnChain], references: [orderIdOnChain])

  @@map("disputes")
}
